# ─── Borrelle Offline Agent — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values.

# LLM server (llama.cpp)
LLAMA_HOST=http://localhost:8080
LLAMA_MODEL=borrelle-e4b

# Optional: require an API key for llama.cpp
# LLAMA_API_KEY=your-key-here

# Web search (DuckDuckGo doesn't need an API key)
# Tavily (alternative, requires API key):
# TAVILY_API_KEY=tvly-...
